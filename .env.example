# Development (optional)
# When empty in dev, app uses Vite proxy (/api)
# VITE_API_URL=http://localhost:3000

# Production
VITE_API_URL=https://api-feicon.onrender.com

# Supabase S3 avatars (object key should match user UUID)
VITE_SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
VITE_SUPABASE_S3_BUCKET=avatars
SUPABASE_S3_SECRET=your-secret

# Optional log level: set to debug to enable verbose frontend logs
# VITE_LOG_LEVEL=debug
